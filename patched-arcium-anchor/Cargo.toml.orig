[package]
name = "arcium-anchor"
description = "A helper crate for integrating Arcium into Solana programs."
version.workspace = true
edition = "2021"
license = "GPL-3.0-or-later"
homepage = "https://www.arcium.com"

[lib]
name = "arcium_anchor"

[dependencies]
anchor-lang.workspace = true
anchor-spl.workspace = true

arcium-client = { path = "../client", default-features = false, version = "=0.8.5" }
arcium-macros = { path = "../macros", version = "=0.8.5" }
sha2-const-stable = "0.1.0"
solana-alt-bn128-bls.workspace = true
solana-address-lookup-table-interface.workspace = true

[features]
default = []
idl-build = ["anchor-lang/idl-build"]
# Enables multi-transaction callback support for large computation outputs (>1232 bytes)
multi-tx-callbacks = []
